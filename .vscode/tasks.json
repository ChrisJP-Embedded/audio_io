{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "example: list devices",
      "type": "shell",
      "command": "poetry",
      "args": [
        "run",
        "python",
        "examples/list_devices.py"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "example: 1000 Hz sine output",
      "type": "shell",
      "command": "poetry",
      "args": [
        "run",
        "python",
        "examples/sine_output.py",
        "--interface",
        "${input:outputInterface}",
        "--frequency",
        "1000",
        "--channels",
        "0,1",
        "--amplitude",
        "0.2",
        "--phase-degrees",
        "${input:sinePhaseDegrees}"
      ],
      "group": "build",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "example: input dB meter",
      "type": "shell",
      "command": "poetry",
      "args": [
        "run",
        "python",
        "examples/input_level_meter.py",
        "--interface",
        "${input:inputInterface}",
        "--channels",
        "0"
      ],
      "group": "test",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "example: loopback sine level check",
      "type": "shell",
      "command": "poetry",
      "args": [
        "run",
        "python",
        "examples/loopback_sine_level_check.py",
        "--interface",
        "${input:loopbackInterface}",
        "--input-channels",
        "${input:loopbackInputChannels}",
        "--output-channels",
        "${input:loopbackOutputChannels}",
        "--sine-dbfs",
        "${input:loopbackSineDbfs}",
        "--tolerance-db",
        "${input:loopbackToleranceDb}"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test: pytest",
      "type": "shell",
      "command": "poetry",
      "args": [
        "run",
        "python",
        "-m",
        "pytest"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "clean: python caches",
      "type": "shell",
      "command": "Get-ChildItem -Force -Recurse -Directory -Include __pycache__,.pytest_cache,.ruff_cache,.mypy_cache,.cache,cache,build,dist,*.egg-info | Remove-Item -Recurse -Force; Get-ChildItem -Force -Recurse -File -Include *.pyc,*.pyo,.coverage | Remove-Item -Force",
      "windows": {
        "command": "Get-ChildItem -Force -Recurse -Directory -Include __pycache__,.pytest_cache,.ruff_cache,.mypy_cache,.cache,cache,build,dist,*.egg-info | Remove-Item -Recurse -Force; Get-ChildItem -Force -Recurse -File -Include *.pyc,*.pyo,.coverage | Remove-Item -Force"
      },
      "osx": {
        "command": "find . \\( -name __pycache__ -o -name .pytest_cache -o -name .ruff_cache -o -name .mypy_cache -o -name .cache -o -name cache -o -name build -o -name dist -o -name '*.egg-info' \\) -type d -prune -exec rm -rf {} +; find . \\( -name '*.pyc' -o -name '*.pyo' -o -name .coverage \\) -type f -delete"
      },
      "linux": {
        "command": "find . \\( -name __pycache__ -o -name .pytest_cache -o -name .ruff_cache -o -name .mypy_cache -o -name .cache -o -name cache -o -name build -o -name dist -o -name '*.egg-info' \\) -type d -prune -exec rm -rf {} +; find . \\( -name '*.pyc' -o -name '*.pyo' -o -name .coverage \\) -type f -delete"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "outputInterface",
      "type": "promptString",
      "description": "Output interface name substring or index",
      "default": "2"
    },
    {
      "id": "inputInterface",
      "type": "promptString",
      "description": "Input interface name substring or index",
      "default": "0"
    },
    {
      "id": "sinePhaseDegrees",
      "type": "promptString",
      "description": "Initial sine phase offset in degrees",
      "default": "0"
    },
    {
      "id": "loopbackInterface",
      "type": "promptString",
      "description": "Loopback interface name substring or index",
      "default": "2"
    },
    {
      "id": "loopbackInputChannels",
      "type": "promptString",
      "description": "Loopback input channels",
      "default": "0"
    },
    {
      "id": "loopbackOutputChannels",
      "type": "promptString",
      "description": "Loopback output channels",
      "default": "0,1"
    },
    {
      "id": "loopbackSineDbfs",
      "type": "promptString",
      "description": "Generated sine peak level in dBFS",
      "default": "-12"
    },
    {
      "id": "loopbackToleranceDb",
      "type": "promptString",
      "description": "Allowed level error in dB",
      "default": "1"
    }
  ]
}
